          ),

          const SizedBox(height: 12),

          // View Details button - small and premium
          if (!isDragging)
            MouseRegion(
              cursor: SystemMouseCursors.click,
              child: InkWell(
                onTap: () => showTaskDetailsDialog(context, task),
                borderRadius: BorderRadius.circular(8),
